{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.glavo.site/hmcl/account-private-data/1.0.0",
  "title": "HMCL Account Private Data",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "$schema",
    "protection",
    "payload"
  ],
  "oneOf": [
    {
      "required": [
        "protection",
        "payload"
      ],
      "properties": {
        "protection": {
          "const": "hmcl-obfuscated-v1"
        },
        "payload": {
          "type": "string"
        }
      }
    },
    {
      "required": [
        "protection",
        "payload"
      ],
      "properties": {
        "protection": {
          "const": "plain"
        },
        "payload": {
          "$ref": "#/$defs/plainPayload"
        }
      }
    }
  ],
  "patternProperties": {
    "^\\$schema$": {
      "enum": [
        "https://schemas.glavo.site/hmcl/account-private-data/1.0.0"
      ]
    }
  },
  "properties": {
    "protection": {
      "enum": [
        "hmcl-obfuscated-v1",
        "plain"
      ]
    },
    "payload": {}
  },
  "$defs": {
    "plainPayload": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "entries"
      ],
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "identifier",
              "privateData"
            ],
            "properties": {
              "identifier": {
                "type": "object",
                "additionalProperties": true,
                "required": [
                  "type"
                ],
                "properties": {
                  "type": {
                    "type": "string"
                  }
                }
              },
              "privateData": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        }
      }
    }
  }
}
