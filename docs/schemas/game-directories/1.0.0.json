{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.glavo.site/hmcl/game-directories/1.0.0",
  "title": "HMCL Game Directories",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "$schema"
  ],
  "patternProperties": {
    "^\\$schema$": {
      "enum": [
        "https://schemas.glavo.site/hmcl/game-directories/1.0.0"
      ]
    }
  },
  "properties": {
    "directories": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gameDirectory"
      }
    }
  },
  "$defs": {
    "gameDirectory": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "path"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/gameDirectoryID"
        },
        "name": {
          "$ref": "#/$defs/localizedText"
        },
        "path": {
          "type": "string"
        },
        "legacyGameSettings": {
          "$ref": "#/$defs/gameSettingsPresetID"
        }
      }
    },
    "gameDirectoryID": {
      "type": "string",
      "pattern": "^game-directory:[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "gameSettingsPresetID": {
      "type": "string",
      "pattern": "^game-settings-preset:[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "localizedText": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string"
          }
        }
      ]
    }
  }
}
