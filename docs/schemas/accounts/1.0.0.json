{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.glavo.site/hmcl/accounts/1.0.0",
  "title": "HMCL Accounts",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "$schema"
  ],
  "patternProperties": {
    "^\\$schema$": {
      "enum": [
        "https://schemas.glavo.site/hmcl/accounts/1.0.0"
      ]
    }
  },
  "properties": {
    "accounts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "accountID"
        ],
        "properties": {
          "accountID": {
            "$ref": "#/$defs/accountID"
          }
        },
        "not": {
          "anyOf": [
            {
              "required": [
                "accessToken"
              ]
            },
            {
              "required": [
                "refreshToken"
              ]
            },
            {
              "required": [
                "clientToken"
              ]
            }
          ]
        }
      }
    }
  },
  "$defs": {
    "accountID": {
      "type": "string",
      "pattern": "^account:[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    }
  }
}
