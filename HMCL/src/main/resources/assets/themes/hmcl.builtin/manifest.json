{
  "$schema": "https://schemas.glavo.site/hmcl/theme-pack/1.0.0",
  "id": "hmcl.builtin",
  "version": "1.0.0",
  "name": {
    "default": "HMCL",
    "zh-Hans": "HMCL",
    "zh-Hant": "HMCL"
  },
  "description": {
    "default": "Built-in launcher themes",
    "zh-Hans": "启动器内置主题",
    "zh-Hant": "啟動器內建主題"
  },
  "authors": [
    {
      "name": "HMCL"
    }
  ],
  "themes": [
    {
      "id": "DEFAULT",
      "name": {
        "default": "Default",
        "zh-Hans": "默认",
        "zh-Hant": "預設"
      },
      "color": "#5C6BC0",
      "brightness": "light",
      "colorStyle": "fidelity",
      "background": {
        "type": "builtin",
        "id": "hmcl.builtin.wallpaper.2021-08-26",
        "opacity": 1.0,
        "fallback": {
          "type": "builtin"
        },
        "loadPolicy": "wait_for_background"
      },
      "titleBar": {
        "transparent": false
      }
    },
    {
      "id": "CLASSIC",
      "name": {
        "default": "Classic",
        "zh-Hans": "经典",
        "zh-Hant": "經典"
      },
      "color": "#5C6BC0",
      "brightness": "light",
      "colorStyle": "fidelity",
      "background": {
        "type": "builtin",
        "id": "hmcl.builtin.wallpaper.2016-02-25",
        "opacity": 1.0,
        "fallback": {
          "type": "builtin"
        },
        "loadPolicy": "wait_for_background"
      },
      "titleBar": {
        "transparent": true
      }
    }
  ]
}
